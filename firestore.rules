rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------- Helper Functions ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Validation Blueprint: Users
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 150
        && data.gender is string && data.gender.size() <= 100
        && data.country is string && data.country.size() <= 100
        && data.goldBalance is int;
    }

    // Validation Blueprint: Stories
    function isValidStory(data) {
      return data.title is string && data.title.size() <= 100
        && data.category is string && data.category.size() <= 100
        && data.userId == request.auth.uid
        && data.authorId == request.auth.uid
        && data.commentCount is int
        && data.goldReceived is int;
    }

    // Validation Blueprint: Comments
    function isValidComment(data) {
      return data.storyId is string && data.storyId.size() <= 128
        && data.text is string && data.text.size() <= 2000
        && data.authorId == request.auth.uid
        && data.userId == request.auth.uid
        && data.replyCount is int
        && data.approved is bool;
    }

    // Cross-user operations from original rules
    function isCrossUserLikesChange(userId) {
      return isSignedIn()
        && request.auth.uid != userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesReceived'])
        && (request.resource.data.likesReceived == resource.data.get('likesReceived', 0) + 1
            || request.resource.data.likesReceived == resource.data.get('likesReceived', 0) - 1);
    }

    function isCrossUserGoldReceivedIncrement(userId) {
      return isSignedIn()
        && request.auth.uid != userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['goldReceived'])
        && request.resource.data.goldReceived > resource.data.get('goldReceived', 0)
        && request.resource.data.goldReceived <= resource.data.get('goldReceived', 0) + 100;
    }

    function isCrossUserFollowChange(userId) {
      return isSignedIn()
        && request.auth.uid != userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'following'])
        && (request.resource.data.followers == resource.data.followers
            || request.resource.data.following == resource.data.following);
    }

    // Story helper functions
    function storyAuthorId(data) {
      return data.authorId != null ? data.authorId : data.userId;
    }

    function storyContentUnchanged() {
      return request.resource.data.title == resource.data.title
        && request.resource.data.text == resource.data.text
        && request.resource.data.category == resource.data.category;
    }

    function storyLedgerOnlyUpdate() {
      return storyContentUnchanged()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['reactions', 'goldReceived', 'totalGold', 'commentCount', 'loveCount', 'likes', 'goldDonations', 'donations', 'approved', 'visibility', 'pinnedCommentId']);
    }

    // Comment helper functions
    function isReplyCountIncrement() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['replyCount'])
        && request.resource.data.replyCount == resource.data.replyCount + 1;
    }

    function isCommentReactionUpdate() {
      return isSignedIn()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions']);
    }

    // ---------- USERS COLLECTION ----------
    match /users/{userId} {
      allow read: if isSignedIn();
      
      // Allow profile creation during sign-up (before email verification is finished)
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(request.resource.data) && request.resource.data.isAdmin == false;
      
      allow update: if isSignedIn() && isValidUser(request.resource.data) && (
        isOwner(userId) || 
        isAdmin() || 
        isCrossUserLikesChange(userId) ||
        isCrossUserGoldReceivedIncrement(userId) ||
        isCrossUserFollowChange(userId)
      ) && (
        // Prevent upgrading to admin unless already an admin
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']) || request.resource.data.get('isAdmin', false) == false || (resource != null && resource.data.get('isAdmin', false) == true) || isAdmin())
      );
      
      allow delete: if isVerified() && (isOwner(userId) || isAdmin());

      // User Bookmarks Subcollection
      match /bookmarks/{bookmarkId} {
        allow read: if isVerified() && request.auth.uid == userId;
        allow write: if isVerified() && request.auth.uid == userId && isValidId(bookmarkId);
      }

      // User Reactions Subcollection
      match /reactions/{reactionId} {
        allow read: if isVerified() && request.auth.uid == userId;
        allow write: if isVerified() && request.auth.uid == userId && isValidId(reactionId);
      }

      // User Comment Reactions Subcollection
      match /commentReactions/{reactionId} {
        allow read: if isVerified() && request.auth.uid == userId;
        allow write: if isVerified() && request.auth.uid == userId && isValidId(reactionId);
      }
    }

    // ---------- STORIES COLLECTION ----------
    match /stories/{storyId} {
      allow read: if (
        resource.data.approved == true && (
          resource.data.visibility == 'public' || 
          (isSignedIn() && resource.data.userId == request.auth.uid)
        )
      ) || (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()));
      
      allow create: if isVerified()
        && isValidId(storyId)
        && isValidStory(request.resource.data);
      
      allow update: if isVerified() && isValidStory(request.resource.data) && (
        resource.data.userId == request.auth.uid || 
        resource.data.authorId == request.auth.uid || 
        isAdmin() ||
        storyLedgerOnlyUpdate() ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'reactions', 'commentCount', 'goldReceived', 'totalGold', 'pinnedCommentId'
          ])
        )
      ) && (
        // Enforce approval state remains intact unless modified by an Admin
        request.resource.data.approved == resource.data.approved || isAdmin()
      );
      
      allow delete: if (isVerified() && (resource.data.userId == request.auth.uid || storyAuthorId(resource.data) == request.auth.uid)) || isAdmin();

      // Edit History Subcollection
      match /editHistory/{historyId} {
        allow read: if isVerified();
        allow create: if isVerified()
          && isValidId(historyId)
          && storyAuthorId(get(/databases/$(database)/documents/stories/$(storyId)).data) == request.auth.uid;
        allow update, delete: if false;
      }

      // Comments Subcollection under Stories
      match /comments/{commentId} {
        allow create: if isVerified()
          && isValidId(commentId)
          && isValidComment(request.resource.data)
          && exists(/databases/$(database)/documents/stories/$(storyId));
        allow update, delete: if isVerified()
          && (resource.data.authorId == request.auth.uid || resource.data.userId == request.auth.uid)
          || isAdmin();
      }
    }

    // ---------- COMMENTS (top-level) ----------
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isVerified()
        && isValidId(commentId)
        && isValidComment(request.resource.data)
        && exists(/databases/$(database)/documents/stories/$(request.resource.data.storyId));
      
      allow update: if isVerified() && (
        isAdmin() ||
        (get(/databases/$(database)/documents/stories/$(resource.data.storyId)).data.userId == request.auth.uid) ||
        (get(/databases/$(database)/documents/stories/$(resource.data.storyId)).data.authorId == request.auth.uid) ||
        ((resource.data.userId == request.auth.uid || resource.data.authorId == request.auth.uid) && 
         (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPinned']))) ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'replyCount'])) ||
        isReplyCountIncrement() ||
        isCommentReactionUpdate()
      );
      
      allow delete: if isVerified() && (
        resource.data.userId == request.auth.uid || 
        resource.data.authorId == request.auth.uid || 
        isAdmin() ||
        (get(/databases/$(database)/documents/stories/$(resource.data.storyId)).data.userId == request.auth.uid) ||
        (get(/databases/$(database)/documents/stories/$(resource.data.storyId)).data.authorId == request.auth.uid)
      );
    }

    // Nested comments under any path
    match /{path=**}/comments/{commentId} {
      allow create: if isVerified() && isValidId(commentId) && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isVerified()
        && (resource.data.authorId == request.auth.uid || resource.data.userId == request.auth.uid)
        || isAdmin();
    }

    // ---------- LOVE LEADERBOARD ----------
    match /loveLeaderboard/{userId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(userId);
      allow update: if isVerified() 
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['totalPoints', 'updatedAt', 'userId', 'authorId', 'userName'])
        && (request.resource.data.totalPoints - resource.data.get('totalPoints', 0)) in [-1, 1];
      allow delete: if false;

      match /events/{eventId} {
        allow read: if true;
        allow create: if isVerified()
          && isValidId(eventId)
          && request.resource.data.userId == userId
          && request.resource.data.authorId == userId
          && request.resource.data.reactorUid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // ---------- NOTIFICATIONS ----------
    match /notifications/{notifId} {
      allow read: if isVerified() && resource.data.toUid == request.auth.uid;
      allow create: if isVerified() && (request.resource.data.fromUid == request.auth.uid || (request.resource.data.fromUid == 'creator' && request.resource.data.toUid == request.auth.uid));
      allow update: if isVerified() && resource.data.toUid == request.auth.uid;
      allow delete: if isVerified() && resource.data.toUid == request.auth.uid;
    }

    // ---------- DAILY CLAIMS ----------
    match /dailyClaims/{uid} {
      allow read, write: if isVerified() && isOwner(uid);
    }

    // ---------- GOLD TRANSACTIONS ----------
    match /goldTransactions/{txId} {
      allow read: if isVerified() && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid || isAdmin());
      allow create: if isVerified() 
        && isValidId(txId)
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.authorId is string;
      allow update, delete: if false;
    }

    // ---------- SUGGESTIONS ----------
    match /suggestions/{suggestionId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(suggestionId) && request.resource.data.userId == request.auth.uid;
      allow update: if isVerified() 
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ---------- BUG COLLECTIONS ----------
    match /bug-fix/{bugId} {
      allow read: if true;
      allow create: if isVerified() && isValidId(bugId);
      allow update, delete: if isAdmin();
    }
    
    match /bugFixes/{fixId} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    
    match /bugs/{bugId} {
      allow read: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidId(bugId) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ---------- FLAGGED REPORTS ----------
    match /flaggedReports/{id} {
      allow read: if isAdmin();
      allow create: if isVerified() && isValidId(id);
      allow update, delete: if isAdmin();
    }

    // ---------- FEEDBACK ----------
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000;
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ---------- REPORTS ----------
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isVerified() && isValidId(reportId) && request.resource.data.reportedBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ---------- DONATIONS ----------
    match /donations/{donationId} {
      allow read: if isVerified() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isVerified() && isValidId(donationId) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }
  }
}
